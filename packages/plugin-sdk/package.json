{
  "name": "@altnautica/plugin-sdk",
  "version": "1.0.0",
  "license": "GPL-3.0-or-later",
  "description": "Public TypeScript SDK for ADOS Mission Control plugins (browser side).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./harness": {
      "types": "./dist/harness.d.ts",
      "default": "./dist/harness.js"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "prepack": "pnpm build"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
